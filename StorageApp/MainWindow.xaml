<Window x:Class="StorageApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StorageApp"
        xmlns:pages="clr-namespace:StorageApp.Pages"
        xmlns:classes="clr-namespace:StorageApp.Classes"
        mc:Ignorable="d"
        
        Background="Transparent"
        ResizeMode="CanResize"
        Icon="/Images/AppIcon.png"
        MinHeight="200"
        MinWidth="300"
        Title="StorageCleaner" Height="650" Width="1200">
    
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1" CornerRadius="15" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="7"/>
    </WindowChrome.WindowChrome>
    
    <Grid Background="Transparent">
        <Border CornerRadius="7"
                Background="{StaticResource BackgroundColor}"
                ClipToBounds="True"
                BorderThickness="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!--    Toolbar     -->
                <Border Grid.Row="0" Grid.ColumnSpan="2"
                        Panel.ZIndex="1"
                        Background="{StaticResource TitleBarColor}"
                        MouseDown="TitleBar_MouseDown"
                        CornerRadius="7,7,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                                          BlurRadius="15"
                                          ShadowDepth="5"
                                          Opacity="0.1"
                                          Direction="270"/>
                    </Border.Effect>
                    
                  
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="190" />
                        </Grid.ColumnDefinitions>
                        <Image Source="/Images/AppIcon.png" RenderOptions.BitmapScalingMode="HighQuality" Margin="10">
                            <Image.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="10"
                                                  ShadowDepth="3"
                                                  Opacity="0.5"
                                                  Direction="-30"/>
                            </Image.Effect>
                        </Image>
                        <!-- Close,Min,Max buttons -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="5" Grid.Column="2">
                            <Border MouseLeftButtonDown="MinButton" Margin="6,0,6,0" CornerRadius="5" Width="30" Height="30" HorizontalAlignment="Center">
                            
                                <Path IsEnabled="False" Data="M0,15 M0,1 L15,1" 
                                      Stroke="{StaticResource TextColor}" 
                                      StrokeThickness="1" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseDirectlyOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SelectionColor}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border MouseLeftButtonDown="MaxButton"  Margin="6,0,6,0" CornerRadius="5" Width="30" Height="30" HorizontalAlignment="Center">
                            
                                <Path IsEnabled="False" Data="M0,0 L8,0 L8,8 L0,8 Z" 
                                      Stroke="{StaticResource TextColor}" 
                                      StrokeThickness="1" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseDirectlyOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SelectionColor}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border  MouseLeftButtonDown="CloseButton" Margin="6,0,6,0" CornerRadius="5" Width="30" Height="30" HorizontalAlignment="Center">
                            
                                <Path IsEnabled="False" Data="M0,0 L9,9 M0,9 L9,0" 
                                      Stroke="{StaticResource TextColor}" 
                                      StrokeThickness="1" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseDirectlyOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SelectionColor}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                          
                        </StackPanel>
                        <!--              -->
                        
                        <!--   Tab buttons   -->
                        <Border Grid.Column="1"></Border>
                        <ItemsControl Grid.Column="1" 
                                      x:Name="NavBar"
                                      ItemsSource="{Binding TitleBarButtons}"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="6"
                                      VerticalContentAlignment="Stretch">
                            
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <!--              -->
                    </Grid>
                   
                    
                </Border>
                <!--              -->
                <ContentControl Grid.Row="1" 
                                x:Name="PageContent"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.0" To="1.0" 
                                                             Duration="0:0:0.3" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
                    

            </Grid>
        </Border>
    </Grid>
</Window>