<UserControl x:Class="StorageApp.Pages.HomeScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StorageApp.Pages"
             xmlns:classes="clr-namespace:StorageApp.Classes"
             xmlns:global="clr-namespace:"
             d:Background="Black"
             d:DesignWidth="1200" d:DesignHeight="650"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <global:FileIconConverter x:Key="IconConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Height="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/> <ColumnDefinition Width="80"/>  <ColumnDefinition Width="80"/>  <ColumnDefinition Width="70"/>  <ColumnDefinition Width="70"/>  <ColumnDefinition Width="200"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

            <TextBlock Text="Name" FontWeight="Bold" Margin="25,0,0,0" Grid.Column="0" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="Size" FontWeight="Bold" TextAlignment="Right" Padding="0,0,5,0" Grid.Column="1" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="Space" FontWeight="Bold" TextAlignment="Right" Padding="0,0,5,0" Grid.Column="2" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="Items" FontWeight="Bold" TextAlignment="Right" Padding="0,0,5,0" Grid.Column="3" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="Folder" FontWeight="Bold" TextAlignment="Right" Padding="0,0,5,0" Grid.Column="4" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="% Parent" FontWeight="Bold" TextAlignment="Center" Margin="5,0,0,0" Grid.Column="5" Foreground="{StaticResource TextColor}"/>
            <TextBlock Text="Changed" FontWeight="Bold" Margin="5,0,0,0" Grid.Column="6" Foreground="{StaticResource TextColor}"/>
            
            <StackPanel Margin="0,-4,0,0" Grid.Column="6">
                <Border MouseDown="Reload_OnMouseDown" VerticalAlignment="Center" HorizontalAlignment="Right" CornerRadius="4" Padding="6" Width="29" Margin="0,0,5,0">
                    
                    <Image IsEnabled="False" Margin="2" Opacity="0.5"  RenderOptions.BitmapScalingMode="HighQuality"  Source="pack://application:,,,/Images/Reload.png">
                   
                    </Image>
                    
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                
                            <Style.Triggers>
                                <Trigger Property="IsMouseDirectlyOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectionColor}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsLoading , RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
               
            </StackPanel>
        </Grid>
        
       
        
        <classes:Spinner  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" x:Name="Spinner" Grid.Row="1"/>
        
       <TreeView x:Name="TreeView" Grid.Row="1" ItemsSource="{Binding StorageItems}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderColor}" Background="Transparent">
           
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="ItemRight_Click"/>
                  
                    <Style.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E0E0E0"/>
                    </Style.Resources>
                </Style>
            </TreeView.ItemContainerStyle>
            
            <TreeView.ItemTemplate>
               <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                  
                   <StackPanel Orientation="Horizontal" Height="22">
                      
                       <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem IsEnabled="False" Header="{Binding Name}" />
                                <Separator />
                                <MenuItem Header="Open Folder Location" Click="OpenFolder_Click" Tag="{Binding Path}">
                                    <MenuItem.Icon>
                                        <Image Source="/Images/HardDrive.png" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                              
                                <MenuItem Header="Open in new Tab" Click="OpenNewWindow_Click" Tag="{Binding Path}" />
                            </ContextMenu>
                        </StackPanel.ContextMenu>

                       
                        <StackPanel Orientation="Horizontal" Width="150" VerticalAlignment="Center">
                            <Image x:Name="ItemIcon"
                                  Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource IconConverter}">
                                        <Binding Path="Path" IsAsync="True" />
                                        <Binding Path="Type" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                       
                        
                        
                        <Grid x:Name="DiskProgressBarGrid" Width="100" Margin="4,2,8,2">
                            <Border CornerRadius="5" BorderThickness="1"
                                    BorderBrush="{StaticResource BorderColor}"
                                    Background="{StaticResource SecondaryBackgroundColor}"/>
    
                            <ProgressBar Foreground="{StaticResource SelectionColor}"
                                         Value="{Binding SizePercentage, Mode=OneWay}" Maximum="100" Minimum="0"
                                         BorderThickness="0" Background="Transparent"/>
    
                            <TextBlock Text="{Binding SizePercentage, Mode=OneWay, StringFormat={}{0:F1}%}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </Grid>

                     
                        <TextBlock Width="80" Text="{Binding SizeDisplay}" TextAlignment="Right"
                                   Padding="0,0,5,0" Foreground="{StaticResource TextColor}"
                                   VerticalAlignment="Center"/>

                      
                        <TextBlock Width="80" x:Name="AllocatedDisplayText" Text="{Binding AllocatedDisplay}" TextAlignment="Right"
                                   Padding="0,0,5,0" Foreground="{StaticResource TextColor}"
                                   VerticalAlignment="Center"/>

                      
                        <TextBlock Width="70" Text="{Binding FilesCount}" TextAlignment="Right"
                                   Padding="0,0,5,0" Foreground="{StaticResource TextColor}"
                                   VerticalAlignment="Center"/>

                      
                        <TextBlock Width="70" Text="{Binding FoldersCount}" TextAlignment="Right"
                                   Padding="0,0,5,0" Foreground="{StaticResource TextColor}"
                                   VerticalAlignment="Center"/>

                       
                        <Grid Width="200" Margin="4,2,8,2">
                            <Border CornerRadius="5" BorderThickness="1"
                                    BorderBrush="{StaticResource BorderColor}"
                                    Background="{StaticResource SecondaryBackgroundColor}"/>
                            <ProgressBar Foreground="{StaticResource SelectionColor}"
                                         Value="{Binding Percentage, Mode=OneWay}" Maximum="100" Minimum="0"
                                         BorderThickness="0" Background="Transparent"/>
                            <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </Grid>

                       
                        <TextBlock Text="{Binding DateModified}" Margin="5,0,0,0"
                                   Foreground="#999999" VerticalAlignment="Center"/>
                        

                    </StackPanel>
                   <HierarchicalDataTemplate.Triggers>
                       <DataTrigger Binding="{Binding SizePercentage}" Value="0">
                           <Setter TargetName="DiskProgressBarGrid" Property="Visibility" Value="Collapsed"/>
                           <Setter TargetName="AllocatedDisplayText" Property="Foreground" Value="Transparent"/>
                           <Setter TargetName="AllocatedDisplayText" Property="Width" Value="180"/>
                         
                       </DataTrigger>
                   </HierarchicalDataTemplate.Triggers>
                  
               </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
       
    </Grid>
</UserControl>